<!-- ── APPLICANTS PAGE ── -->
<div class="applicants-wrapper fade-in">

  <div style="display:flex; align-items:center; gap:16px; margin-bottom: 32px; flex-wrap: wrap;">
    <div>
      <h1 class="applicants-title" style="margin-bottom:4px;">Applicants</h1>
      <p style="color: var(--text-muted); font-size: 0.875rem;"><%= candidates.length %> candidate<%= candidates.length !== 1 ? 's' : '' %> found</p>
    </div>
    <a href="javascript:history.back()" class="btn-ghost-modern ms-auto" style="font-size:0.85rem; padding:8px 18px;">
      <i class="fa-solid fa-arrow-left"></i> Back
    </a>
  </div>

  <% if (candidates.length === 0) { %>
    <div style="text-align:center; padding: 80px 20px; color: var(--text-muted);">
      <i class="fa-solid fa-user-slash" style="font-size: 3rem; margin-bottom: 16px; display:block; opacity:0.3;"></i>
      <p style="font-size: 1.1rem; font-weight: 600;">No applicants yet</p>
      <p style="font-size: 0.875rem;">Applications will appear here once candidates apply.</p>
    </div>
  <% } else { %>
    <div style="background: var(--bg-card); backdrop-filter: blur(20px); border: 1px solid var(--border-glass); border-radius: var(--radius-lg); overflow: hidden;">
      <table class="table table-dark mb-0">
        <thead>
          <tr>
            <th scope="col">#</th>
            <th scope="col">Name</th>
            <th scope="col">Email</th>
            <th scope="col">Contact</th>
            <th scope="col">Resume</th>
          </tr>
        </thead>
        <tbody>
          <% candidates.forEach((candidate, index) => { %>
            <tr>
              <th scope="row" style="color: var(--text-muted); font-weight: 500;"><%= index + 1 %></th>
              <td style="font-weight: 600; color: var(--text-primary);"><%= candidate.name %></td>
              <td style="color: var(--text-muted);"><%= candidate.email %></td>
              <td style="color: var(--text-muted);"><%= candidate.contact %></td>
              <td>
                <button
                  class="btn-primary-modern"
                  style="padding: 6px 16px; font-size: 0.78rem; gap:6px;"
                  onclick="viewResume('<%= candidate.imageUrl %>')">
                  <i class="fa-solid fa-file-arrow-down" style="font-size:0.8rem;"></i> View
                </button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<script>
  function viewResume(resumePath) {
    const dummyUrl = new URL(resumePath, window.location.origin);
    window.open(dummyUrl.pathname, '_blank');
  }
</script>
