<!-- ── POST / UPDATE JOB PAGE ── -->
<div class="newjob-wrapper fade-in">
  <div class="newjob-card">

    <h1 class="newjob-title">
      <% if (update) { %>
        <i class="fa-solid fa-pen-to-square me-2" style="color: var(--accent);"></i>Update Job Listing
      <% } else { %>
        <i class="fa-solid fa-plus-circle me-2" style="color: var(--primary);"></i>Post a New Job
      <% } %>
    </h1>

    <form action="<%= update ? '/update/' + jobDetails.job_id : '/newjob' %>" method="post">

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">

        <div class="mb-3">
          <label class="form-label">Job Category</label>
          <select class="form-control form-select" name="job_category" required>
            <option disabled <%= !update ? 'selected' : '' %>>Select category</option>
            <option <%= update && jobDetails.job_category === 'Tech' ? 'selected' : '' %>>Tech</option>
            <option <%= update && jobDetails.job_category === 'Non Tech' ? 'selected' : '' %>>Non Tech</option>
          </select>
        </div>

        <div class="mb-3">
          <label class="form-label">Role / Designation</label>
          <select class="form-control form-select" name="role" required>
            <option disabled <%= !update ? 'selected' : '' %>>Select role</option>
            <% ['HR','SDE','DevOps','Mern Developer','Mean Developer','JAVA Developer','Front-End Developer','Back-End Developer','Angular Developer'].forEach(r => { %>
              <option <%= update && jobDetails.role === r ? 'selected' : '' %>><%= r %></option>
            <% }) %>
          </select>
        </div>

        <div class="mb-3">
          <label class="form-label">Company Name</label>
          <input type="text" class="form-control" name="company_name"
            placeholder="e.g. Acme Corp"
            value="<%= update ? jobDetails.company_name : '' %>" required>
        </div>

        <div class="mb-3">
          <label class="form-label">Location</label>
          <input type="text" class="form-control" name="location"
            placeholder="e.g. Bengaluru, Remote"
            value="<%= update ? jobDetails.location : '' %>" required>
        </div>

        <div class="mb-3">
          <label class="form-label">Salary Package</label>
          <input type="text" class="form-control" name="pack"
            placeholder="e.g. 12-18lpa"
            value="<%= update ? jobDetails.pack : '' %>" required>
        </div>

        <div class="mb-3">
          <label class="form-label">Total Openings</label>
          <input type="number" class="form-control" name="numberofopenings"
            placeholder="e.g. 5"
            value="<%= update ? jobDetails.numberofopenings : '' %>" min="1">
        </div>

        <div class="mb-3">
          <label class="form-label">Apply By</label>
          <input type="date" class="form-control" name="apply_by"
            value="<%= update ? jobDetails.apply_by : '' %>">
        </div>

      </div>

      <div class="mb-4">
        <label class="form-label">Required Skills <span style="color:var(--text-muted);font-size:0.75rem;">(Hold Ctrl/Cmd to select multiple)</span></label>
        <select multiple class="form-control" name="skills" style="min-height: 130px;" required>
          <% ['React','NodeJs','Angular','MongoDB','SQL','Express','Java','SpringBoot','C++','Data Structures & Algo','AWS','Docker','Python','TypeScript'].forEach(skill => { %>
            <option value="<%= skill %>"
              <%= update && jobDetails.skills && jobDetails.skills.includes(skill) ? 'selected' : '' %>>
              <%= skill %>
            </option>
          <% }) %>
        </select>
      </div>

      <div style="display:flex; gap:12px; justify-content:center;">
        <button type="submit" class="btn-primary-modern" style="padding:13px 36px; font-size:0.95rem;">
          <i class="fa-solid fa-<%= update ? 'floppy-disk' : 'rocket' %>"></i>
          <%= update ? 'Save Changes' : 'Post Job' %>
        </button>
        <a href="/jobs" class="btn-ghost-modern" style="padding:12px 24px; font-size:0.9rem;">
          Cancel
        </a>
      </div>
    </form>
  </div>
</div>
