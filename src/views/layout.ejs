<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Easily – Find reliable job opportunities and internships in an instant.">
    <title>Easily – Find Jobs & Internships</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Syne:wght@700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://kit.fontawesome.com/2e6169f7f0.js" crossorigin="anonymous"></script>
  </head>
  <body class="<%= isMainPage ? 'main-page' : '' %>">

    <!-- ── NAVBAR ── -->
    <nav class="navbar navbar-expand-lg">
      <div class="container-fluid px-4">
        <a class="navbar-brand" href="/">Easily</a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
          <i class="fa-solid fa-bars" style="color: var(--text-muted);"></i>
        </button>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-2">
            <li class="nav-item">
              <a class="nav-link active" aria-current="page" href="/"><i class="fa-solid fa-house me-1" style="font-size:0.75rem;"></i>Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/jobs"><i class="fa-solid fa-briefcase me-1" style="font-size:0.75rem;"></i>Jobs</a>
            </li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="fa-solid fa-user-circle me-1" style="font-size:0.75rem;"></i><%= locals.userEmail ? locals.name : 'Recruiter' %>
              </a>
              <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="<%= locals.userEmail ? '/logout' : '/login' %>">
                  <i class="fa-solid <%= locals.userEmail ? 'fa-arrow-right-from-bracket' : 'fa-arrow-right-to-bracket' %> me-2"></i><%= locals.userEmail ? 'Logout' : 'Login' %>
                </a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item" href="/newjob"><i class="fa-solid fa-plus-circle me-2"></i>Post New Job</a></li>
              </ul>
            </li>
          </ul>
          <form class="d-flex align-items-center gap-2" role="search" action="/search" method="GET">
            <input class="form-control nav-search-input" type="search" name="query" placeholder="Search jobs, skills…" aria-label="Search">
            <button class="btn-ghost-modern" type="submit" style="padding:9px 18px;font-size:0.82rem;">Search</button>
          </form>
        </div>
      </div>
    </nav>

    <!-- ── PAGE CONTENT ── -->
    <div class="<%= isMainPage ? '' : 'container py-2' %>">
      <%- body %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
  </body>
</html>