<!-- ── ERROR PAGE ── -->
<div class="error-page-wrapper fade-in">

  <div class="error-img-wrap">
    <img src="/sad404.svg" alt="Error illustration">
  </div>

  <div class="error-code">Oops!</div>

  <div class="error-message">
    <span class="highlight"><%= message %></span>
  </div>

  <div style="display:flex; gap:12px; flex-wrap:wrap; justify-content:center;">
    <a href="/" class="btn-primary-modern">
      <i class="fa-solid fa-house"></i> Go Home
    </a>
    <a href="javascript:history.back()" class="btn-ghost-modern">
      <i class="fa-solid fa-arrow-left"></i> Go Back
    </a>
  </div>

</div>
