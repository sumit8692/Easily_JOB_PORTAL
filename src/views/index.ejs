<!-- ── HERO SECTION ── -->
<section class="hero-section fade-in">

  <!-- Left: text content -->
  <div class="hero-content">
    <div class="hero-badge">🚀 Now Hiring Nationwide</div>

    <h1 class="hero-title">
      Find your next<br>
      <span class="gradient-text">dream career</span>
    </h1>

    <div class="typed-out">One stop search for Jobs</div>

    <p class="hero-tagline">Get Discovered. Get Hired.</p>
    <p class="hero-desc">
      A comprehensive platform connecting talented professionals with top recruiters —
      from startups to Fortune 500. Opportunities in tech, finance, design, and more.
    </p>

    <div class="hero-actions">
      <a href="/jobs" class="btn-primary-modern">
        <i class="fa-solid fa-briefcase"></i> Browse Jobs
      </a>
      <% if (!locals.userEmail) { %>
        <button type="button" class="btn-ghost-modern" data-bs-toggle="modal" data-bs-target="#recruiterModal">
          <i class="fa-solid fa-user-tie"></i> I'm a Recruiter
        </button>
      <% } else { %>
        <a href="/newjob" class="btn-ghost-modern">
          <i class="fa-solid fa-plus"></i> Post a Job
        </a>
      <% } %>
    </div>

    <% if (locals.lastVisit) { %>
      <div class="last-visit-chip">
        <i class="fa-regular fa-clock"></i> Last visited: <%= locals.lastVisit %>
      </div>
    <% } %>
  </div>

  <!-- Right: hero illustration -->
  <div class="hero-image-wrap">
    <img src="banner.png" alt="Job seekers illustration">
  </div>
</section>

<!-- ── RECRUITER REGISTER MODAL ── -->
<div class="modal fade" id="recruiterModal" tabindex="-1" aria-labelledby="recruiterModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">

      <div class="modal-header">
        <div>
          <h5 class="modal-title" id="recruiterModalLabel">
            <i class="fa-solid fa-user-tie me-2" style="color: var(--primary);"></i>Join as Recruiter
          </h5>
          <p style="color: var(--text-muted); font-size: 0.8rem; margin: 4px 0 0;">Post jobs and discover top talent instantly.</p>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body">
        <form action="/registerRecruiter" method="post">
          <div class="mb-3">
            <label for="reg-name" class="form-label">Full Name</label>
            <input type="text" class="form-control" id="reg-name" name="name" placeholder="e.g. Priya Sharma" required>
          </div>
          <div class="mb-3">
            <label for="reg-email" class="form-label">Email Address</label>
            <input type="email" class="form-control" id="reg-email" name="email" placeholder="recruiter@company.com" required>
            <div class="form-text">We'll never share your email with anyone.</div>
          </div>
          <div class="mb-4">
            <label for="reg-password" class="form-label">Password</label>
            <input type="password" class="form-control" id="reg-password" name="password" placeholder="Min. 6 characters" required>
          </div>
          <button type="submit" class="btn-primary-modern w-100" style="width:100%;justify-content:center;">
            <i class="fa-solid fa-rocket"></i> Register Now
          </button>
        </form>

        <div style="margin-top: 20px; text-align: center; color: var(--text-muted); font-size: 0.85rem;">
          Already registered?&nbsp;
          <a href="/login" style="color: var(--primary-glow); font-weight: 600; text-decoration: none;">Login here →</a>
        </div>

        <div class="social-icons" style="justify-content: center; margin-top: 16px;">
          <i class="fa-brands fa-instagram" id="instagram"></i>
          <i class="fa-brands fa-twitter" id="twitter"></i>
          <i class="fa-brands fa-whatsapp" id="whatsapp"></i>
          <i class="fa-brands fa-linkedin" id="linkedin"></i>
        </div>
      </div>
    </div>
  </div>
</div>