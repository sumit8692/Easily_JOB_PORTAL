<!-- ── JOBS PAGE ── -->
<div class="jobs-page-wrapper">

  <div class="jobs-page-header fade-in">
    <h1>Open Positions</h1>
    <p>Discover curated opportunities from top companies</p>
  </div>

  <div class="card-container">
    <% jobs.forEach((job, idx) => { %>
      <div class="job-card fade-in" style="animation-delay: <%= idx * 0.07 %>s;">

        <div class="hiring-badge">
          <i class="fa-solid fa-arrow-trend-up"></i> Actively Hiring
        </div>

        <div>
          <div class="company-name"><%= job.company_name %></div>
          <div class="job-category"><%= job.job_category %></div>
        </div>

        <div class="role"><%= job.role %></div>

        <div class="location">
          <i class="fa-solid fa-location-dot"></i> <%= job.location %>
        </div>

        <div class="package">
          <i class="fa-solid fa-indian-rupee-sign" style="font-size:0.8rem; color: var(--gold);"></i>
          <%= job.pack %>
        </div>

        <div style="display:flex; flex-wrap:wrap; gap:2px; margin-top: 4px;">
          <% job.skills.forEach(skill => { %>
            <button type="button" class="btn-outline-info ml-1 mb-1"><%= skill %></button>
          <% }) %>
        </div>

        <a href="/jobs/<%= job.job_id %>" class="card-link" style="text-decoration:none; margin-top: auto;">
          <button class="view-details-btn">View Details <i class="fa-solid fa-arrow-right ms-1" style="font-size:0.8rem;"></i></button>
        </a>

      </div>
    <% }) %>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
  <div style="display: flex; justify-content: center; align-items: center; padding: 32px 0;">
    <nav aria-label="Jobs pagination">
      <ul class="pagination">
        <% if (currentPage > 1) { %>
          <li class="page-item">
            <a class="page-link" href="?page=1" aria-label="First">
              <i class="fa-solid fa-angles-left" style="font-size:0.75rem;"></i>
            </a>
          </li>
          <li class="page-item">
            <a class="page-link" href="?page=<%= currentPage - 1 %>" aria-label="Previous">
              <i class="fa-solid fa-angle-left" style="font-size:0.75rem;"></i>
            </a>
          </li>
        <% } %>

        <% for (let i = 1; i <= totalPages; i++) { %>
          <li class="page-item <%= i === currentPage ? 'active' : '' %>">
            <a class="page-link" href="?page=<%= i %>"><%= i %></a>
          </li>
        <% } %>

        <% if (currentPage < totalPages) { %>
          <li class="page-item">
            <a class="page-link" href="?page=<%= currentPage + 1 %>" aria-label="Next">
              <i class="fa-solid fa-angle-right" style="font-size:0.75rem;"></i>
            </a>
          </li>
          <li class="page-item">
            <a class="page-link" href="?page=<%= totalPages %>" aria-label="Last">
              <i class="fa-solid fa-angles-right" style="font-size:0.75rem;"></i>
            </a>
          </li>
        <% } %>
      </ul>
    </nav>
  </div>
  <% } %>

</div>
